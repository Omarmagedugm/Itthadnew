{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "avatar": { "type": "string" },
        "location": { "type": "string" },
        "joinDate": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "predictions": { "type": "number" },
            "comments": { "type": "number" },
            "favorites": { "type": "number" }
          }
        }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "News": {
      "title": "News",
      "description": "News articles and RSS feeds",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "type": { "type": "string", "enum": ["manual", "rss"] },
        "rssUrl": { "type": "string" }
      }
    },
    "Match": {
      "title": "Match",
      "description": "Match score and details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homeTeam": { "type": "string" },
        "awayTeam": { "type": "string" },
        "homeLogo": { "type": "string" },
        "awayLogo": { "type": "string" },
        "homeScore": { "type": "string" },
        "awayScore": { "type": "string" },
        "date": { "type": "string" },
        "competition": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "live", "finished"] }
      }
    },
    "Club": {
      "title": "Club",
      "description": "Club name and logo",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" }
      }
    },
    "Poll": {
      "title": "Poll",
      "description": "Fan polls",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "votes": { "type": "object" },
        "voters": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "Prediction": {
      "title": "Prediction",
      "description": "User match prediction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "matchId": { "type": "string" },
        "userId": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "FanPost": {
      "title": "Fan Post",
      "description": "User shared post in fan zone",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "likes": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string" }
      }
    },
    "Media": {
      "title": "Media",
      "description": "Photos and videos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "thumbnail": { "type": "string" },
        "type": { "type": "string", "enum": ["photo", "video"] },
        "date": { "type": "string" }
      }
    },
    "LiveComment": {
      "title": "Live Comment",
      "description": "Comments in live chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "AppSetting": {
      "title": "App Setting",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "appName": { "type": "string" },
        "appLogo": { "type": "string" },
        "primaryColor": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Collection of user profiles" },
    "news": { "schema": "News", "description": "Collection of news articles" },
    "matches": { "schema": "Match", "description": "Collection of matches" },
    "clubs": { "schema": "Club", "description": "Collection of club logos" },
    "polls": { "schema": "Poll", "description": "Collection of fan polls" },
    "predictions": { "schema": "Prediction", "description": "Collection of match predictions" },
    "fan_posts": { "schema": "FanPost", "description": "Community posts" },
    "media": { "schema": "Media", "description": "Collection of media items" },
    "live_comments": { "schema": "LiveComment", "description": "Live match comments" },
    "settings": { "schema": "AppSetting", "description": "Global settings" }
  }
}
